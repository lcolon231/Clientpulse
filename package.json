{
  "name": "clientpulse",
  "version": "0.1.0",
  "description": "Multi-tenant MSP client health dashboard — built on Next.js, Supabase, and Prisma",
  "repository": {
    "type": "git",
    "url": "https://github.com/lcolon231/Clientpulse.git"
  },
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "analyze": "ANALYZE=true pnpm build",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
