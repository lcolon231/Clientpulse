# =============================================================================
# ClientPulse — environment variable contract
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER-ONLY  — these vars are never sent to the browser.
# Do NOT prefix them with NEXT_PUBLIC_.
# Do NOT reference them in 'use client' files.
# lib/env.ts enforces this at Next.js build time via the `server-only` package.
# -----------------------------------------------------------------------------

# Supabase Postgres — transaction-mode pooler URL (port 6543).
# Prisma uses this for all runtime queries (pgBouncer-compatible).
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string → Transaction
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase Postgres — direct (non-pooled) URL (port 5432).
# Prisma uses this only for migrations (`prisma migrate` / `prisma db push`).
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string → Direct
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres"

# Supabase service-role key — has admin privileges, bypasses RLS.
# ⚠️  KEEP SECRET. Used server-side for: creating Auth users, deleting orphaned
#     Auth users on failed signup, and any future admin operations.
# Get this from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# -----------------------------------------------------------------------------
# CLIENT-SAFE  — safe to expose in the browser. Must use NEXT_PUBLIC_ prefix.
# These are embedded in the JS bundle at build time.
# -----------------------------------------------------------------------------

# Supabase project URL.
# Get this from: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"

# Supabase anon (public) key — safe for browsers; RLS enforces data isolation.
# Get this from: Supabase Dashboard → Project Settings → API → anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Full origin URL of this app — used in Supabase auth email links (invite, reset).
# Dev: http://localhost:3000   Prod: https://your-app.vercel.app
# Must NOT have a trailing slash.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# WEEK 5 — Reports & Alerts
# -----------------------------------------------------------------------------

# Resend API key — used for monthly PDF email reports and threshold alerts.
# Get this from: https://resend.com/api-keys
RESEND_API_KEY="re_..."

# Cron secret — Vercel attaches this as `Authorization: Bearer <CRON_SECRET>`
# on every cron invocation. Must match the value set in Vercel project settings.
# Generate a strong random string: openssl rand -hex 32
CRON_SECRET="your-cron-secret-here"

# -----------------------------------------------------------------------------
# WEEK 6 — Billing & Subscriptions (Stripe)
# -----------------------------------------------------------------------------

# Stripe secret key — server-side only. Used to create customers, checkout
# sessions, and billing portal sessions.
# Get this from: Stripe Dashboard → Developers → API keys → Secret key
STRIPE_SECRET_KEY="sk_test_..."

# Stripe webhook signing secret — verifies that webhook payloads come from Stripe.
# Get this from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# For local development use the Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs — create these in the Stripe Dashboard (Products → Add product).
# Each price ID corresponds to a recurring subscription price.
# Starter plan price ID
STRIPE_PRICE_STARTER="price_..."
# Growth plan price ID
STRIPE_PRICE_GROWTH="price_..."
# Enterprise plan price ID
STRIPE_PRICE_ENTERPRISE="price_..."

# -----------------------------------------------------------------------------
# WEEK 7 — PSA Ticket Sync (ConnectWise / Autotask)
# -----------------------------------------------------------------------------

# Required only when more than one organization exists in the database. Prevents
# a server-env PSA credential set from being synced into the wrong tenant.
PSA_SYNC_ORGANIZATION_ID=""

# Number of days of ticket history each cron run fetches.
TICKET_SYNC_LOOKBACK_DAYS="30"

# ConnectWise Manage REST API credentials.
# Base URL example: https://api-na.myconnectwise.net
CONNECTWISE_BASE_URL=""
CONNECTWISE_COMPANY_ID=""
CONNECTWISE_PUBLIC_KEY=""
CONNECTWISE_PRIVATE_KEY=""
CONNECTWISE_CLIENT_ID=""

# Autotask REST API credentials.
# Base URL example: https://webservices.autotask.net/ATServicesRest/V1.0
AUTOTASK_BASE_URL=""
AUTOTASK_USERNAME=""
AUTOTASK_SECRET=""
AUTOTASK_INTEGRATION_CODE=""
