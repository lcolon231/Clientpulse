# =============================================================================
# ClientPulse — environment variable contract
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER-ONLY  — these vars are never sent to the browser.
# Do NOT prefix them with NEXT_PUBLIC_.
# Do NOT reference them in 'use client' files.
# lib/env.ts enforces this at Next.js build time via the `server-only` package.
# -----------------------------------------------------------------------------

# Supabase Postgres — transaction-mode pooler URL (port 6543).
# Prisma uses this for all runtime queries (pgBouncer-compatible).
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string → Transaction
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase Postgres — direct (non-pooled) URL (port 5432).
# Prisma uses this only for migrations (`prisma migrate` / `prisma db push`).
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string → Direct
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres"

# Supabase service-role key — has admin privileges, bypasses RLS.
# ⚠️  KEEP SECRET. Used server-side for: creating Auth users, deleting orphaned
#     Auth users on failed signup, and any future admin operations.
# Get this from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# -----------------------------------------------------------------------------
# CLIENT-SAFE  — safe to expose in the browser. Must use NEXT_PUBLIC_ prefix.
# These are embedded in the JS bundle at build time.
# -----------------------------------------------------------------------------

# Supabase project URL.
# Get this from: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"

# Supabase anon (public) key — safe for browsers; RLS enforces data isolation.
# Get this from: Supabase Dashboard → Project Settings → API → anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
