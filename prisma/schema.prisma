generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: url and directUrl are not supported here.
  // Migration URL → prisma.config.ts  datasource.url  (DIRECT_URL, port 5432)
  // Runtime URL   → lib/db/prisma.ts  PrismaPg adapter (DATABASE_URL, port 6543)
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  OWNER
  TECHNICIAN
  READONLY
}

enum SlaTier {
  BASIC
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum TicketSource {
  CONNECTWISE
  AUTOTASK
}

enum TicketStatus {
  NEW
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  UNKNOWN
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

/// The MSP tenant. Every other record hangs off one Organization.
model Organization {
  id                   String   @id @default(cuid())
  name                 String
  /// Subscription plan: "STARTER" | "GROWTH" | "ENTERPRISE"
  plan                 String   @default("STARTER")
  stripeCustomerId     String?  @map("stripe_customer_id")
  stripeSubscriptionId String?  @map("stripe_subscription_id")
  onboardingComplete   Boolean  @default(false) @map("onboarding_complete")
  timezone             String   @default("UTC")
  logoUrl              String?  @map("logo_url")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  users         User[]
  clients       Client[]
  auditLogs     AuditLog[]
  alertLogs     AlertLog[]
  notifications Notification[]
  tickets       Ticket[]

  @@map("organizations")
}

/// An employee/user of the MSP. Linked to a Supabase Auth user via supabaseUserId.
model User {
  id             String       @id @default(cuid())
  /// auth.users.id from Supabase — the UUID Supabase Auth issues on sign-up.
  supabaseUserId String       @unique @map("supabase_user_id")
  email          String       @unique
  /// Display name set by the user on accept-invite (or left null for existing owners).
  name           String?
  role           Role         @default(TECHNICIAN)
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  auditLogs       AuditLog[]
  assignedTickets Ticket[]        @relation("TicketAssignee")
  ticketComments  TicketComment[]

  @@index([organizationId])
  @@map("users")
}

/// A small-business client that the MSP manages.
model Client {
  id             String       @id @default(cuid())
  name           String
  industry       String       @default("Other")
  slaTier        SlaTier      @default(STANDARD) @map("sla_tier")
  primaryContact String?      @map("primary_contact")
  notes          String?
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  devices Device[]
  tickets Ticket[]

  @@index([organizationId])
  @@map("clients")
}

/// A managed endpoint (workstation, server, NAS, etc.) belonging to a Client.
model Device {
  id           String   @id @default(cuid())
  hostname     String
  // TODO (Week 2): convert to enum once device-type taxonomy is defined
  type         String
  os           String
  osVersion    String   @map("os_version")
  lastSeen     DateTime @map("last_seen")
  patchAgeDays Int      @map("patch_age_days")
  tags         String[]
  clientId     String   @map("client_id")
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clientId])
  @@map("devices")
}

/// Ticket rows — either synced read-only from PSA (source is set) or created natively (source is null).
model Ticket {
  id                  String          @id @default(cuid())
  organizationId      String          @map("organization_id")
  organization        Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId            String?         @map("client_id")
  client              Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  /// null = native ticket; non-null = PSA-synced ticket
  source              TicketSource?
  externalId          String?         @map("external_id")
  externalCompanyId   String?         @map("external_company_id")
  externalCompanyName String?         @map("external_company_name")
  number              String?
  title               String
  description         String?
  status              TicketStatus    @default(OPEN)
  priority            TicketPriority  @default(MEDIUM)
  /// Text assignee from PSA sync (not a User FK)
  assignee            String?
  /// User FK for natively-created tickets
  assigneeId          String?         @map("assignee_id")
  assigneeUser        User?           @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  dueDate             DateTime?       @map("due_date")
  url                 String?
  externalCreatedAt   DateTime?       @map("external_created_at")
  externalUpdatedAt   DateTime?       @map("external_updated_at")
  resolvedAt          DateTime?       @map("resolved_at")
  syncedAt            DateTime?       @default(now()) @map("synced_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  comments TicketComment[]

  @@unique([organizationId, source, externalId])
  @@index([organizationId])
  @@index([clientId])
  @@index([status])
  @@index([priority])
  @@index([externalCreatedAt])
  @@map("tickets")
}

/// Comment on a ticket — works for both PSA-synced and natively-created tickets.
model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String   @map("ticket_id")
  userId    String   @map("user_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_comments")
}

/// Tracks sent alert emails to prevent duplicate alerts within a 7-day window.
model AlertLog {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entityType     String       @map("entity_type") // "device" | "client"
  entityId       String       @map("entity_id")
  alertType      String       @map("alert_type")  // "patch_age" | "health_critical"
  sentAt         DateTime     @default(now()) @map("sent_at")

  @@index([organizationId])
  @@index([entityType, entityId, alertType, sentAt])
  @@map("alert_logs")
}

/// In-app notification surfaced in the nav bell.
model Notification {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  userId         String?      @map("user_id")
  title          String
  body           String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  linkHref       String?      @map("link_href")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("notifications")
}

/// Immutable append-only record written on every mutation.
model AuditLog {
  id             String       @id @default(cuid())
  action         String
  entityType     String       @map("entity_type")
  entityId       String       @map("entity_id")
  /// Arbitrary JSON payload — diff, old/new values, request context, etc.
  metadata       Json         @default("{}")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Nullable: system-initiated actions may not have a user (e.g. scheduled jobs).
  userId         String?      @map("user_id")
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
